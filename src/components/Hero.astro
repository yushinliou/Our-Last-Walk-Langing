---
---

<section class="hero">
  <div class="hero-bg">
    <div class="hero-parallax-layer hero-img-bg"></div>
    <div class="fog-layer"></div>
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <img
      src="/gamecover.png"
      alt="Our Last Walk"
      class="hero-logo"
      loading="eager"
    />
    <p class="tagline">Some walks lead us home. Some lead us to let go.</p>
    <div class="hero-cta-group">
      <a href="#story" class="hero-cta">Discover the Story</a>
      <a href="https://github.com/yushinliou/Our-Last-Walk-Langing/releases/download/v1.0.0/final-build.zip" download class="hero-cta hero-cta-download">Download Game</a>
    </div>
  </div>

  <div class="scroll-indicator">
    <span class="paw-bounce">🐾</span>
    <span class="scroll-text">Scroll</span>
  </div>
</section>

<style>
.hero {
  position: relative;
  height: 100vh;
  min-height: 600px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  color: var(--cream-50);
}

.hero-bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.hero-img-bg {
  position: absolute;
  inset: -10%;
  background: url('/gamecover.png') center center / cover no-repeat;
  filter: brightness(0.25) blur(2px);
  will-change: transform;
}

.fog-layer {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 120% 60% at 30% 60%, rgba(94,179,179,0.08) 0%, transparent 60%),
    radial-gradient(ellipse 80% 40% at 70% 40%, rgba(212,168,75,0.06) 0%, transparent 60%);
  animation: fogDrift 25s ease-in-out infinite alternate;
  will-change: opacity;
}

@keyframes fogDrift {
  from { opacity: 0.6; transform: translateX(0); }
  to { opacity: 1; transform: translateX(2%); }
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(26,26,26,0.3) 0%,
    rgba(26,26,26,0.15) 40%,
    rgba(26,26,26,0.6) 100%
  );
}

.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 2rem;
  animation: heroFadeIn 1s ease-out forwards;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
}

@keyframes heroFadeIn {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.hero-logo {
  width: min(420px, 80vw);
  height: auto;
  filter: drop-shadow(0 0 40px rgba(94,179,179,0.3));
}

.tagline {
  font-family: var(--font-display);
  font-size: clamp(1rem, 2.5vw, 1.4rem);
  font-style: italic;
  color: var(--cream-100);
  max-width: 520px;
  opacity: 0;
  animation: heroFadeIn 1s ease-out 0.6s forwards;
  line-height: 1.6;
}

.hero-cta-group {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
  opacity: 0;
  animation: heroFadeIn 1s ease-out 1s forwards;
}

.hero-cta {
  display: inline-block;
  padding: 0.75rem 2rem;
  border: 1px solid var(--gold-400);
  color: var(--gold-400);
  font-family: var(--font-ui);
  font-size: 0.85rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  transition: background 0.3s, color 0.3s;
}

.hero-cta:hover {
  background: var(--gold-400);
  color: var(--dark-900);
}

.hero-cta-download {
  background: var(--gold-400);
  color: var(--dark-900);
}

.hero-cta-download:hover {
  background: transparent;
  color: var(--gold-400);
}

.scroll-indicator {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  opacity: 0;
  animation: heroFadeIn 1s ease-out 1.4s forwards;
}

.paw-bounce {
  font-size: 1.5rem;
  animation: paw 1.5s ease-in-out infinite;
}

@keyframes paw {
  0%, 100% { transform: translateY(0); opacity: 1; }
  50% { transform: translateY(8px); opacity: 0.6; }
}

.scroll-text {
  font-family: var(--font-ui);
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--cream-200);
}
</style>
