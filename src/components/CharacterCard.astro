---
interface Props {
  name: string;
  subtitle: string;
  image: string;
  abilities: string[];
  accentColor: string;
  glowColor: string;
}

const { name, subtitle, image, abilities, accentColor, glowColor } = Astro.props;
---

<div class="char-card" style={`--accent: ${accentColor}; --glow: ${glowColor};`}>
  <div class="char-image-wrap">
    <img src={image} alt={name} class="char-image" loading="lazy" />
    <div class="char-glow"></div>
  </div>
  <div class="char-info">
    <h3 class="char-name">{name}</h3>
    <p class="char-subtitle">{subtitle}</p>
    <ul class="char-abilities">
      {abilities.map(ability => (
        <li class="char-ability">
          <span class="ability-dot"></span>
          {ability}
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
.char-card {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 4px;
  padding: 2rem;
  text-align: center;
  transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  cursor: default;
}

.char-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 60px -10px var(--glow);
  border-color: var(--accent);
}

.char-image-wrap {
  position: relative;
  width: 200px;
  height: 200px;
  margin: 0 auto 1.5rem;
}

.char-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  position: relative;
  z-index: 1;
  transition: filter 0.3s;
}

.char-card:hover .char-image {
  filter: drop-shadow(0 0 16px var(--glow));
}

.char-glow {
  position: absolute;
  inset: -10px;
  border-radius: 50%;
  background: radial-gradient(circle, var(--glow) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.3s;
  z-index: 0;
}

.char-card:hover .char-glow {
  opacity: 0.3;
}

.char-name {
  font-family: var(--font-display);
  font-size: 1.8rem;
  font-weight: 700;
  color: var(--accent);
  margin-bottom: 0.25rem;
}

.char-subtitle {
  font-family: var(--font-ui);
  font-size: 0.8rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--cream-200);
  opacity: 0.7;
  margin-bottom: 1.5rem;
}

.char-abilities {
  list-style: none;
  text-align: left;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.char-ability {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.95rem;
  color: var(--cream-100);
}

.ability-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
}
</style>
