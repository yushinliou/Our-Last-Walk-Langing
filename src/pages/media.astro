---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import VideoPlayer from '../components/VideoPlayer.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Media" description="Watch trailers and explore screenshots from Our Last Walk — a first-person puzzle game about companionship.">
  <Navigation />

  <main class="media-main">

    <!-- Page Header -->
    <header class="media-header">
      <div class="container">
        <h1 class="reveal" style="font-family: var(--font-display); font-size: clamp(2.5rem,6vw,4rem); font-weight:700; color: var(--gold-400); margin-bottom: 1rem;">
          Media
        </h1>
        <p class="media-lead reveal">
          Trailers, gameplay footage, and a glimpse into the world of <em>Our Last Walk</em>.
        </p>
      </div>
    </header>

    <!-- Gameplay Videos -->
    <section class="videos-section">
      <div class="container">
        <h2 class="section-title reveal" style="color: var(--gold-400);">In Motion</h2>
        <p class="section-subtitle reveal">See the world through the eyes of a ghost — and his dog.</p>

        <!-- Featured video -->
        <div class="featured-video reveal">
          <VideoPlayer
            src="/Lucky_7_Intro_sm.mov"
            caption="Intro Cinematic — Lucky 7 Studio"
            featured={true}
          />
        </div>

        <!-- Secondary gameplay videos -->
        <div class="video-grid">
          <div class="reveal">
            <VideoPlayer
              src="/gameplay/ourlastwalk_bedroom%20(1).mp4"
              caption="Bedroom Exploration"
            />
          </div>
          <div class="reveal">
            <VideoPlayer
              src="/gameplay/Place%20Photo%20(1).mov"
              caption="Placing Objects"
            />
          </div>
          <div class="reveal">
            <VideoPlayer
              src="/gameplay/readobj%20(1).mov"
              caption="Office Object Interaction"
            />
          </div>
          <div class="reveal">
            <VideoPlayer
              src="/gameplay/Screen%20Recording%202026-05-06%20at%2011.43.10%20AM%20(1).mov"
              caption="Gameplay Recording"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Screenshots Gallery -->
    <section class="screenshots-section">
      <div class="container">
        <h2 class="section-title reveal" style="color: var(--gold-400); text-align: center;">A Glimpse Into the World</h2>
        <p class="section-subtitle reveal" style="text-align: center;">In-game art and environments from Our Last Walk.</p>

        <div class="screenshot-grid">
          <figure class="shot-item reveal">
            <a href="/gamecover.png" target="_blank" rel="noopener">
              <img src="/gamecover.png" alt="Game Cover Art" loading="lazy" />
            </a>
            <figcaption>Game Cover Art</figcaption>
          </figure>

          <figure class="shot-item reveal">
            <a href="/MrRich.png" target="_blank" rel="noopener">
              <img src="/MrRich.png" alt="Mr. Rich — the Ghost" loading="lazy" />
            </a>
            <figcaption>Mr. Rich — The Ghost</figcaption>
          </figure>

          <figure class="shot-item reveal">
            <a href="/angel.png" target="_blank" rel="noopener">
              <img src="/angel.png" alt="Angel — the Dog" loading="lazy" />
            </a>
            <figcaption>Angel — The Dog</figcaption>
          </figure>

          <figure class="shot-item reveal">
            <a href="/gallery/mia7house.jpg" target="_blank" rel="noopener">
              <img src="/gallery/mia7house.jpg" alt="Mia's Drawing: The House" loading="lazy" />
            </a>
            <figcaption>Mia's Drawing: The House</figcaption>
          </figure>

          <figure class="shot-item reveal">
            <a href="/gallery/mia6.jpg" target="_blank" rel="noopener">
              <img src="/gallery/mia6.jpg" alt="Scene — In-Game" loading="lazy" />
            </a>
            <figcaption>Mia's Drawing: Childhood</figcaption>
          </figure>

          <figure class="shot-item reveal">
            <a href="/gallery/mia6bikes.jpg" target="_blank" rel="noopener">
              <img src="/gallery/mia6bikes.jpg" alt="Mia's Drawing: By the Bikes" loading="lazy" />
            </a>
            <figcaption>Mia's Drawing: By the Bikes</figcaption>
          </figure>

          <figure class="shot-item reveal">
            <a href="/gallery/mia11.jpg" target="_blank" rel="noopener">
              <img src="/gallery/mia11.jpg" alt="Narrative Scene" loading="lazy" />
            </a>
            <figcaption>Mia's Drawing: Dear Mama!</figcaption>
          </figure>

          <figure class="shot-item reveal">
            <a href="/gallery/mia10sad.jpg" target="_blank" rel="noopener">
              <img src="/gallery/mia10sad.jpg" alt="A Moment of Sadness" loading="lazy" />
            </a>
            <figcaption>Mia's Drawing: Dear Parents</figcaption>
          </figure>

          <figure class="shot-item reveal">
            <a href="/gallery/photo.jpg" target="_blank" rel="noopener">
              <img src="/gallery/photo.jpg" alt="In-Game Photo" loading="lazy" />
            </a>
            <figcaption>Mr. Rich and her Wife</figcaption>
          </figure>

          <figure class="shot-item reveal">
            <a href="/gallery/photo-threedudes.jpg" target="_blank" rel="noopener">
              <img src="/gallery/photo-threedudes.jpg" alt="Three Characters" loading="lazy" />
            </a>
            <figcaption>Mr. Rich and His Friends</figcaption>
          </figure>

          <figure class="shot-item reveal">
            <a href="/gallery/token-kitchen-outline.png" target="_blank" rel="noopener">
              <img src="/gallery/token-kitchen-outline.png" alt="Kitchen — Concept Art" loading="lazy" />
            </a>
            <figcaption>Angel's Collar</figcaption>
          </figure>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
.media-main {
  padding-top: 80px;
  min-height: 100vh;
  background: var(--dark-900);
}

/* Header */
.media-header {
  padding: 6rem 0 4rem;
  background: linear-gradient(to bottom, var(--dark-900), var(--dark-800));
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.media-lead {
  font-size: 1.2rem;
  line-height: 1.7;
  color: var(--cream-100);
  max-width: 600px;
  opacity: 0.9;
}

.media-lead em {
  color: var(--ghost-400);
  font-style: italic;
}

/* Videos section */
.videos-section {
  padding: 6rem 0;
  background: var(--dark-900);
}

.featured-video {
  margin-bottom: 2.5rem;
}

.video-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}

/* Screenshots section */
.screenshots-section {
  padding: 6rem 0;
  background: linear-gradient(to bottom, var(--dark-800), var(--dark-900));
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.screenshot-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
  margin-top: 3rem;
}

.shot-item {
  margin: 0;
}

.shot-item a {
  display: block;
  overflow: hidden;
  border-radius: 4px;
  border: 1px solid rgba(255, 255, 255, 0.07);
  transition: border-color 0.3s, transform 0.3s;
}

.shot-item a:hover {
  border-color: var(--gold-400);
  transform: translateY(-4px);
}

.shot-item img {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  display: block;
  transition: transform 0.4s;
}

.shot-item a:hover img {
  transform: scale(1.04);
}

.shot-item figcaption {
  margin-top: 0.5rem;
  font-family: var(--font-ui);
  font-size: 0.8rem;
  color: var(--cream-200);
  opacity: 0.65;
  letter-spacing: 0.03em;
  text-align: center;
}

/* Responsive */
@media (max-width: 768px) {
  .video-grid {
    grid-template-columns: 1fr;
  }

  .screenshot-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 480px) {
  .screenshot-grid {
    grid-template-columns: 1fr;
  }
}
</style>
