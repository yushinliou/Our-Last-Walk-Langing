---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import StorySection from '../components/StorySection.astro';
import CharacterCard from '../components/CharacterCard.astro';
import MechanicsSection from '../components/MechanicsSection.astro';
import ScreenshotGallery from '../components/ScreenshotGallery.astro';
import TeamMember from '../components/TeamMember.astro';
import Footer from '../components/Footer.astro';

const team = [
  { name: 'Anna Likhanova',    role: 'Developer, Narrative Designer and 2D artist', avatar: '/profile/anna.jpg', email: 'anna.likhanova2002@gmail.com',   linkedin: 'https://www.linkedin.com/in/anna-likhanova-ba9478222/' },
  { name: 'Lexi Yu Shin Liou', role: 'Narrative designer, Developer',               avatar: '/profile/lex.jpeg', email: 'vxh440@gmail.com',               linkedin: 'https://www.linkedin.com/in/yu-shin-liou-is-lexi/' },
  { name: 'Apeel Subedi',      role: 'Developer, 3D Artist',                        avatar: '/profile/ape.jpg',  email: 'apeelsubedi@gmail.com',          linkedin: 'https://apeels.com.np' },
  { name: 'Abidin Baran',      role: '3D Environment Artist',                       avatar: '/profile/abi.jpg',  email: 'abidin@example.com',             linkedin: 'https://www.linkedin.com/in/abidin' },
  { name: 'Alfred Malmström',  role: 'Contributor',                                 avatar: '/profile/alf.png',  email: 'alfred@example.com',             linkedin: 'https://www.linkedin.com/in/alfred' },
];
---

<BaseLayout title="Home" description="Our Last Walk — An emotional puzzle game about a ghost and his dog.">
  <Navigation />
  <Hero />

  <!-- Team Members -->
  <section class="team-section">
    <div class="container">
      <h2 class="section-title reveal" style="text-align:center; color: var(--gold-400);">Meet Lucky 7</h2>
      <p class="section-subtitle reveal" style="text-align:center;">Five people. One shared vision. Countless late nights.</p>
      <div class="team-grid">
        {team.map(member => (
          <div class="reveal">
            <TeamMember name={member.name} role={member.role} avatar={member.avatar} email={member.email} linkedin={member.linkedin} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <StorySection />

  <!-- Characters Section -->
  <section class="characters-section">
    <div class="container">
      <h2 class="section-title reveal" style="text-align:center; color: var(--gold-400);">The Characters</h2>
      <p class="section-subtitle reveal" style="text-align:center;">Switch between their perspectives. Use their strengths together.</p>

      <div class="characters-grid">
        <div class="reveal-left">
          <CharacterCard
            name="Mr. Rich"
            subtitle="The Ghost"
            image="/MrRich.png"
            abilities={[
              'See through walls',
              'Control lights',
              'Move objects with his mind',
              'Cannot touch physical things',
            ]}
            accentColor="var(--ghost-400)"
            glowColor="rgba(94,179,179,0.4)"
          />
        </div>

        <div class="character-switch reveal">
          <span class="switch-arrow">⇄</span>
          <span class="switch-label">Switch</span>
        </div>

        <div class="reveal-right">
          <CharacterCard
            name="Angel"
            subtitle="The Dog"
            image="/angel.png"
            abilities={[
              'Squeeze into small spaces',
              'Super smell — see scent trails',
              'Super hearing',
              'Pick up objects with her mouth',
            ]}
            accentColor="var(--amber-400)"
            glowColor="rgba(232,169,82,0.4)"
          />
        </div>
      </div>
    </div>
  </section>

  <MechanicsSection />
  <ScreenshotGallery />
  <Footer />
</BaseLayout>

<style>
.team-section {
  padding: 6rem 0;
  background: linear-gradient(to bottom, var(--dark-900), var(--dark-800));
}

.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1.5rem;
  margin-top: 1rem;
}

.characters-section {
  padding: 8rem 0;
  background: linear-gradient(to bottom, var(--dark-900), var(--dark-800));
}

.characters-grid {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 2rem;
  align-items: center;
  margin-top: 1rem;
}

@media (max-width: 768px) {
  .characters-grid {
    grid-template-columns: 1fr;
  }
  .character-switch {
    justify-self: center;
  }
}

.character-switch {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
}

.switch-arrow {
  font-size: 2rem;
  color: var(--gold-400);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(0.9); }
}

.switch-label {
  font-family: var(--font-ui);
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gold-400);
  opacity: 0.7;
}
</style>
